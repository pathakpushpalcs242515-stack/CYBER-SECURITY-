Design and implement algorithms to encrypt and decrypt messages using  transposition techniques


import math

def encrypt(message, key):
    rows = math.ceil(len(message) / key)
    matrix = [['X' for _ in range(key)] for _ in range(rows)]

    index = 0
    for r in range(rows):
        for c in range(key):
            if index < len(message):
                matrix[r][c] = message[index]
                index += 1

    cipher = ""
    for c in range(key):
        for r in range(rows):
            cipher += matrix[r][c]

    return cipher


def decrypt(cipher, key):
    rows = math.ceil(len(cipher) / key)
    matrix = [['' for _ in range(key)] for _ in range(rows)]

    index = 0
    for c in range(key):
        for r in range(rows):
            if index < len(cipher):
                matrix[r][c] = cipher[index]
                index += 1

    message = ""
    for r in range(rows):
        for c in range(key):
            message += matrix[r][c]

    return message.rstrip('X')


while True:
    print("\nColumnar Transposition Cipher")
    print("1. Encrypt")
    print("2. Decrypt")
    print("3. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        text = input("Enter plaintext: ")
        key = int(input("Enter key (columns): "))
        print("Ciphertext:", encrypt(text, key))

    elif choice == "2":
        text = input("Enter ciphertext: ")
        key = int(input("Enter key (columns): "))
        print("Plaintext:", decrypt(text, key))

    elif choice == "3":
        break

    else:
        print("Invalid choice.")
