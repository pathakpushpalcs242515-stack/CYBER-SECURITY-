# caesar_gui.py

import tkinter as tk

# Encryption Function
def encrypt():
    text = message_entry.get()
    shift = int(key_entry.get())
    result = ""

    for char in text:
        if char.isalpha():
            start = ord('A') if char.isupper() else ord('a')
            result += chr((ord(char) - start + shift) % 26 + start)
        else:
            result += char

    result_label.config(text="Encrypted Text: " + result, fg="green")


# Decryption Function
def decrypt():
    text = message_entry.get()
    shift = int(key_entry.get())
    result = ""

    for char in text:
        if char.isalpha():
            start = ord('A') if char.isupper() else ord('a')
            result += chr((ord(char) - start - shift) % 26 + start)
        else:
            result += char

    result_label.config(text="Decrypted Text: " + result, fg="blue")


# Main Window
root = tk.Tk()
root.title("Caesar Cipher")
root.geometry("450x300")
root.configure(bg="#E8F6F3")   # Light Cyan Background

# Heading
title = tk.Label(
    root,
    text="Caesar Cipher Encryption & Decryption",
    font=("Arial", 16, "bold"),
    bg="#117A65",
    fg="white",
    pady=10
)
title.pack(fill="x")

# Message Label
tk.Label(
    root,
    text="Enter Message:",
    bg="#E8F6F3",
    font=("Arial", 11)
).pack(pady=5)

message_entry = tk.Entry(root, width=35, font=("Arial", 11))
message_entry.pack()

# Key Label
tk.Label(
    root,
    text="Enter Shift Key:",
    bg="#E8F6F3",
    font=("Arial", 11)
).pack(pady=5)

key_entry = tk.Entry(root, width=10, font=("Arial", 11))
key_entry.pack()

# Buttons Frame
frame = tk.Frame(root, bg="#E8F6F3")
frame.pack(pady=15)

encrypt_btn = tk.Button(
    frame,
    text="Encrypt",
    bg="#28B463",
    fg="white",
    font=("Arial", 11, "bold"),
    width=12,
    command=encrypt
)
encrypt_btn.grid(row=0, column=0, padx=10)

decrypt_btn = tk.Button(
    frame,
    text="Decrypt",
    bg="#3498DB",
    fg="white",
    font=("Arial", 11, "bold"),
    width=12,
    command=decrypt
)
decrypt_btn.grid(row=0, column=1, padx=10)

# Result
result_label = tk.Label(
    root,
    text="Result will appear here",
    bg="#E8F6F3",
    font=("Arial", 12, "bold")
)
result_label.pack(pady=15)

root.mainloop()
